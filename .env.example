# ============================================================
# Smart Stadium — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ── Application ────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── Security ───────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ───────────────────────────────────────────────
# Production: use managed Postgres (e.g. Neon, Railway, Supabase)
# Local dev:  postgresql://stadium:stadium@localhost:5432/smart_stadium
DATABASE_URL=postgresql://stadium:REPLACE_PASSWORD@localhost:5432/smart_stadium

POSTGRES_USER=stadium
POSTGRES_PASSWORD=REPLACE_PASSWORD
POSTGRES_DB=smart_stadium

# ── Redis ──────────────────────────────────────────────────
# Production: use managed Redis (e.g. Upstash, Railway)
# Local dev:  redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Qdrant ─────────────────────────────────────────────────
# Production: use managed Qdrant Cloud or self-hosted
# Local dev:  http://localhost:6333
QDRANT_URL=http://localhost:6333

# ── AI / Gemini ────────────────────────────────────────────
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY

# ── CORS (optional) ────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# ALLOWED_ORIGINS=https://stadium.example.com,https://www.stadium.example.com
